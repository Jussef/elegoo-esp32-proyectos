---
import ProjectLayout from '../../layouts/ProjectLayout.astro';
const code = String.raw`// ALARMA DE MOVIMIENTO con LED RGB + Buzzer (un solo "pip")
// HC-SR501 PIR  ->  LED RGB (verde = tranquilo / rojo = alerta) + buzzer activo

#define PIN_PIR    13   // OUT del HC-SR501
#define PIN_BUZZER 14   // Buzzer ACTIVO (suena con HIGH)

// Pines LED RGB (catodo comun)
#define PIN_R 25
#define PIN_G 26
#define PIN_B 33

// Canales PWM (LEDC) para el LED RGB
#define CH_R 0
#define CH_G 1
#define CH_B 2

int estadoAnterior = LOW;

// Pinta el LED RGB con valores 0-255 (catodo comun)
void setColor(int r, int g, int b) {
  ledcWrite(CH_R, r);
  ledcWrite(CH_G, g);
  ledcWrite(CH_B, b);
}

// Un solo "pip" corto y listo (no es sirena)
void pip() {
  digitalWrite(PIN_BUZZER, HIGH);
  delay(120);
  digitalWrite(PIN_BUZZER, LOW);
}

void setup() {
  Serial.begin(115200);
  delay(300);

  pinMode(PIN_PIR, INPUT);
  pinMode(PIN_BUZZER, OUTPUT);
  digitalWrite(PIN_BUZZER, LOW);

  ledcSetup(CH_R, 5000, 8);
  ledcSetup(CH_G, 5000, 8);
  ledcSetup(CH_B, 5000, 8);
  ledcAttachPin(PIN_R, CH_R);
  ledcAttachPin(PIN_G, CH_G);
  ledcAttachPin(PIN_B, CH_B);

  setColor(0, 60, 0);   // verde suave = todo tranquilo

  // El HC-SR501 necesita ~30-60 s para calibrarse al encender
  Serial.println("HC-SR501 calentando (espera ~30 s sin moverte)...");
  delay(2000);
  Serial.println("Listo. Vigilando movimiento...\n");
}

void loop() {
  int estado = digitalRead(PIN_PIR);

  // Solo actuamos cuando CAMBIA el estado (flanco), no en cada vuelta
  if (estado != estadoAnterior) {
    if (estado == HIGH) {
      Serial.println(">> Movimiento DETECTADO");
      setColor(255, 0, 0);   // rojo = alerta
      pip();                 // un unico pip al detectar
    } else {
      Serial.println("   Sin movimiento (reposo)");
      setColor(0, 60, 0);    // vuelve a verde
    }
    estadoAnterior = estado;
  }

  delay(50);
}`;
---
<ProjectLayout title="PIR 01 · Alarma con LED RGB y Buzzer — ESP32" label="PIR 01" pageName="Alarma con LED RGB y Buzzer">
  <section class="section">
    <div class="section-label">Descripción</div>
    <div class="meta">
      <span class="badge facil">Principiante</span>
      <span class="cat-tag">Sensor · LED RGB · Audio</span>
    </div>
    <p class="desc">
      Una pequeña alarma de presencia. En reposo el <strong>LED RGB</strong> brilla en
      <strong>verde</strong> (todo tranquilo). Cuando el <strong>HC-SR501 PIR</strong> detecta
      movimiento, el LED pasa a <strong>rojo</strong> y el <strong>buzzer</strong> hace un único
      <strong>"pip"</strong> corto —sin sirena ni ruido molesto—. Al dejar de detectar movimiento,
      el LED vuelve a verde solo. Ideal para vigilar una puerta, un cajón o tu escritorio.
    </p>
  </section>

  <section class="section">
    <div class="section-label">Componentes</div>
    <div class="comp-list">
      <div class="comp-item"><div class="cdot"></div><span class="cname">ESP-32 Board</span><span class="cqty">1 PC</span></div>
      <div class="comp-item"><div class="cdot"></div><span class="cname">HC-SR501 PIR Sensor</span><span class="cqty">1 PC</span></div>
      <div class="comp-item"><div class="cdot"></div><span class="cname">LED RGB (cátodo común)</span><span class="cqty">1 PC</span></div>
      <div class="comp-item"><div class="cdot"></div><span class="cname">Buzzer activo</span><span class="cqty">1 PC</span></div>
      <div class="comp-item"><div class="cdot"></div><span class="cname">Resistencias 220Ω</span><span class="cqty">3 PCS</span></div>
      <div class="comp-item"><div class="cdot"></div><span class="cname">Protoboard + cables</span><span class="cqty">—</span></div>
    </div>
  </section>

  <section class="section">
    <div class="section-label">Conexiones</div>
    <table>
      <thead>
        <tr><th>Componente</th><th>Pin ESP-32</th><th>Notas</th></tr>
      </thead>
      <tbody>
        <tr><td>HC-SR501 — VCC</td><td><span class="pin">5V (VIN)</span></td><td>El PIR funciona de 4.5V a 20V</td></tr>
        <tr><td>HC-SR501 — OUT</td><td><span class="pin">GPIO 13</span></td><td>Salida digital (3.3V en alto)</td></tr>
        <tr><td>HC-SR501 — GND</td><td><span class="pin">GND</span></td><td>—</td></tr>
        <tr><td>LED R — vía resistor 220Ω</td><td><span class="pin">GPIO 25</span></td><td>Canal Rojo (PWM)</td></tr>
        <tr><td>LED G — vía resistor 220Ω</td><td><span class="pin">GPIO 26</span></td><td>Canal Verde (PWM)</td></tr>
        <tr><td>LED B — vía resistor 220Ω</td><td><span class="pin">GPIO 33</span></td><td>Canal Azul (PWM)</td></tr>
        <tr><td>LED Cátodo (−)</td><td><span class="pin">GND</span></td><td>Pata más larga (cátodo común)</td></tr>
        <tr><td>Buzzer (+)</td><td><span class="pin">GPIO 14</span></td><td>Buzzer <strong>activo</strong>: suena con HIGH</td></tr>
        <tr><td>Buzzer (−)</td><td><span class="pin">GND</span></td><td>—</td></tr>
      </tbody>
    </table>
    <div class="note" style="margin-top:12px;">
      <strong>Usa el buzzer ACTIVO</strong> (el de etiqueta/cerrado por arriba): suena solo con poner el pin
      en alto. Si fuera de ánodo común el LED, conecta el común a 3.3V e invierte los valores con
      <code>255 − valor</code>. El código actual es para <strong>cátodo común</strong>.
    </div>
  </section>

  <section class="section">
    <div class="section-label">Código Arduino</div>
    <div class="code-box">
      <div class="code-header">
        <span class="code-lang">C++ / Arduino IDE (ESP-32)</span>
        <button class="copy-btn" id="copyBtn">Copiar</button>
      </div>
      <pre><code class="language-cpp" id="code" set:html={code}></code></pre>
    </div>
  </section>

  <section class="section">
    <div class="section-label">Cómo usar</div>
    <div class="steps">
      <div class="step"><div class="step-n">1</div><div class="step-text">No necesitas librerías externas: el código solo usa <code>digitalRead()</code> y el PWM nativo del ESP-32 (<code>ledc</code>).</div></div>
      <div class="step"><div class="step-n">2</div><div class="step-text">Conecta el PIR, el LED RGB (con sus 3 resistencias) y el buzzer activo según la tabla.</div></div>
      <div class="step"><div class="step-n">3</div><div class="step-text">Sube el código y abre el <strong>Monitor Serie</strong> a <code>115200</code>. Verás "verde" al arrancar.</div></div>
      <div class="step"><div class="step-n">4</div><div class="step-text"><strong>Espera ~30-60 s sin moverte</strong> mientras el PIR se calibra; luego pasa frente a él: LED rojo + un "pip".</div></div>
      <div class="step"><div class="step-n">5</div><div class="step-text">Al quedarte quieto, tras el tiempo configurado en el potenciómetro del PIR, vuelve a verde.</div></div>
    </div>
    <div class="note">
      <strong>Ajustes:</strong> los dos potenciómetros naranjas del PIR controlan la <strong>sensibilidad</strong>
      (alcance) y el <strong>tiempo</strong> que la salida queda en alto. Para que suene un solo "pip" por
      evento, deja el jumper en <code>L</code> (un disparo) o en <code>H</code> con el tiempo bajo. Puedes
      cambiar la duración del pip ajustando el <code>delay(120)</code> dentro de <code>pip()</code>.
    </div>
  </section>
</ProjectLayout>
