---
import ProjectLayout from '../../layouts/ProjectLayout.astro';
const code = String.raw`#include "BluetoothSerial.h"

// Bluetooth Classic — solo funciona en ESP-32 con soporte BT
// (no en ESP32-S2 o ESP32-C3)
#if !defined(CONFIG_BT_ENABLED) || !defined(CONFIG_BLUEDROID_ENABLED)
  #error Bluetooth no habilitado. Ve a: Arduino IDE -&gt; Herramientas -&gt; Partition Scheme -&gt; Huge APP
#endif

BluetoothSerial BT;
const String DEVICE_NAME = "ESP32-BT";   // Nombre que aparece en el telefono
const int    LED_PIN     = 2;            // LED integrado del ESP-32

void procesarComando(String cmd) {
  cmd.trim();

  if (cmd == "L1") {
    digitalWrite(LED_PIN, HIGH);
    BT.println("LED: ENCENDIDO");
    Serial.println("[BT] LED encendido");

  } else if (cmd == "L0") {
    digitalWrite(LED_PIN, LOW);
    BT.println("LED: APAGADO");
    Serial.println("[BT] LED apagado");

  } else if (cmd == "ST") {
    bool estado = digitalRead(LED_PIN);
    BT.println("Estado LED: " + String(estado ? "ENCENDIDO" : "APAGADO"));

  } else if (cmd.length() &gt; 0) {
    BT.println("Eco: " + cmd);
    Serial.println("[BT] mensaje: " + cmd);
  }
}

void setup() {
  Serial.begin(115200);
  pinMode(LED_PIN, OUTPUT);

  BT.begin(DEVICE_NAME);

  Serial.println("=== Bluetooth Serial ===");
  Serial.println("Dispositivo: " + DEVICE_NAME);
  Serial.println("Busca este nombre en tu telefono y empareja.");
  Serial.println("Comandos: L1 / L0 / ST");
  Serial.println("========================");
}

void loop() {
  // Recibe datos del telefono via Bluetooth
  if (BT.available()) {
    String msg = BT.readStringUntil('\n');
    procesarComando(msg);
  }

  // Reenvía lo que escribas en Monitor Serie al telefono
  if (Serial.available()) {
    String msg = Serial.readStringUntil('\n');
    BT.println(msg);
  }

  delay(20);
}`;
---
<ProjectLayout title="05 · Terminal Bluetooth Serial — ESP32" label="PROYECTO 05" pageName="Terminal Bluetooth Serial">
  <section class="section">
    <div class="section-label">Descripción</div>
    <div class="meta">
      <span class="badge medio">Intermedio</span>
      <span class="cat-tag">Bluetooth · Inalámbrico</span>
    </div>
    <p class="desc">
      El ESP-32 se empareja con tu teléfono vía Bluetooth Classic y crea un canal de comunicación serial
      inalámbrico. Desde una app de terminal en el celular puedes enviar comandos para controlar el LED
      integrado, y el ESP-32 responde con mensajes de confirmación. Todo sin cables ni WiFi.
    </p>
  </section>

  <section class="section">
    <div class="section-label">Componentes</div>
    <div class="comp-list">
      <div class="comp-item"><div class="cdot"></div><span class="cname">ESP-32 Board</span><span class="cqty">1 PC</span></div>
      <div class="comp-item"><div class="cdot"></div><span class="cname">Cable USB A → C (para programar)</span><span class="cqty">1 PC</span></div>
      <div class="comp-item"><div class="cdot"></div><span class="cname">Teléfono Android con Bluetooth</span><span class="cqty">—</span></div>
    </div>
  </section>

  <section class="section">
    <div class="section-label">Conexiones</div>
    <p class="no-wiring">Sin conexiones externas — el LED integrado en GPIO 2 de la placa ESP-32 se usa directamente.</p>
  </section>

  <section class="section">
    <div class="section-label">Comandos disponibles (desde el celular)</div>
    <div class="cmd-grid">
      <div class="cmd-item"><div class="cmd-code">L1</div><div class="cmd-desc">Enciende el LED integrado del ESP-32</div></div>
      <div class="cmd-item"><div class="cmd-code">L0</div><div class="cmd-desc">Apaga el LED integrado del ESP-32</div></div>
      <div class="cmd-item"><div class="cmd-code">ST</div><div class="cmd-desc">Consulta el estado actual del LED (encendido/apagado)</div></div>
      <div class="cmd-item"><div class="cmd-code">cualquier texto</div><div class="cmd-desc">El ESP-32 hace eco del mensaje y lo muestra en el Monitor Serie</div></div>
    </div>
  </section>

  <section class="section">
    <div class="section-label">Código Arduino</div>
    <div class="code-box">
      <div class="code-header">
        <span class="code-lang">C++ / Arduino IDE (ESP-32)</span>
        <button class="copy-btn" id="copyBtn">Copiar</button>
      </div>
      <pre><code class="language-cpp" id="code" set:html={code}></code></pre>
    </div>
  </section>

  <section class="section">
    <div class="section-label">Cómo usar</div>
    <div class="steps">
      <div class="step"><div class="step-n">1</div><div class="step-text">Sube el código al ESP-32 y abre el Monitor Serie a <code>115200</code> baud para ver los mensajes de estado.</div></div>
      <div class="step"><div class="step-n">2</div><div class="step-text">En tu teléfono Android, instala la app <strong>Serial Bluetooth Terminal</strong> (disponible en Play Store, gratis).</div></div>
      <div class="step"><div class="step-n">3</div><div class="step-text">Ve a Configuración → Bluetooth de tu teléfono y empareja con el dispositivo llamado <code>ESP32-BT</code>. PIN: sin PIN o <code>1234</code>.</div></div>
      <div class="step"><div class="step-n">4</div><div class="step-text">Abre la app Serial Bluetooth Terminal, conéctate a <code>ESP32-BT</code> y envía comandos como <code>L1</code>, <code>L0</code>, <code>ST</code>.</div></div>
    </div>
    <div class="note">
      <strong>Nota:</strong> Esta librería usa <em>Bluetooth Classic</em> (no BLE). Solo funciona con Android.
      Para iOS necesitarías usar BLE con la librería <code>NimBLE-Arduino</code>.
    </div>
  </section>
</ProjectLayout>

