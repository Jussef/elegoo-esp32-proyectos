---
import ProjectLayout from '../../layouts/ProjectLayout.astro';
const code = String.raw`#include &lt;WiFi.h&gt;
#include &lt;time.h&gt;
#include &lt;Wire.h&gt;
#include &lt;Adafruit_GFX.h&gt;
#include &lt;Adafruit_SSD1306.h&gt;
#include &lt;Stepper.h&gt;

// ----- WiFi -----
const char* SSID  = "TU_RED_WIFI";
const char* PASS  = "TU_PASSWORD";

// ----- NTP (zona horaria) -----
const long  GMT_OFFSET   = -5 * 3600;  // ajusta a tu huso (ej. -5 = Colombia/Peru)
const int   DST_OFFSET   = 0;          // horario de verano (0 si no aplica)

// ----- OLED -----
#define ANCHO 128
#define ALTO  64
Adafruit_SSD1306 oled(ANCHO, ALTO, &amp;Wire, -1);

// ----- Motor -----
const int STEPS_REV = 2048;
#define IN1 19
#define IN2 18
#define IN3 5
#define IN4 17
Stepper motor(STEPS_REV, IN1, IN3, IN2, IN4);
const long PASOS_DOSIS = STEPS_REV / 4;   // 1/4 de vuelta por racion (ajustable)

// ----- Boton -----
#define PIN_BTN 4

// ----- Horarios de dosis (hora:minuto) -----
const int HORAS[]   = {8, 14, 20};   // 8:00, 14:00 y 20:00
const int MINUTOS[] = {0, 0,  0};
const int N_DOSIS   = 3;

int  racionesServidas = 0;
int  ultimaDosisMin   = -1;   // evita repetir la dosis dentro del mismo minuto

void apagarBobinas() {
  digitalWrite(IN1, LOW); digitalWrite(IN2, LOW);
  digitalWrite(IN3, LOW); digitalWrite(IN4, LOW);
}

void dispensar(const char* origen) {
  Serial.printf("Dispensando (%s)\n", origen);
  motor.step(PASOS_DOSIS);
  apagarBobinas();
  racionesServidas++;
}

void pantalla(const char* hora, const char* prox) {
  oled.clearDisplay();
  oled.setTextColor(SSD1306_WHITE);
  oled.setTextSize(2);  oled.setCursor(0, 0);   oled.println(hora);
  oled.setTextSize(1);  oled.setCursor(0, 26);  oled.print("Proxima: "); oled.println(prox);
  oled.setCursor(0, 42); oled.print("Raciones: "); oled.println(racionesServidas);
  oled.display();
}

void setup() {
  Serial.begin(115200);
  pinMode(PIN_BTN, INPUT_PULLUP);
  Wire.begin(21, 22);
  oled.begin(SSD1306_SWITCHCAPVCC, 0x3C);
  motor.setSpeed(12);

  oled.clearDisplay();
  oled.setTextSize(1); oled.setCursor(0, 0);
  oled.println("Conectando WiFi..."); oled.display();

  WiFi.begin(SSID, PASS);
  while (WiFi.status() != WL_CONNECTED) { delay(400); Serial.print("."); }
  Serial.println("\nWiFi OK");

  // Sincroniza la hora con servidores NTP
  configTime(GMT_OFFSET, DST_OFFSET, "pool.ntp.org", "time.nist.gov");
}

void loop() {
  struct tm t;
  if (!getLocalTime(&amp;t)) { delay(500); return; }

  // Texto de la hora actual HH:MM
  char hora[6];
  strftime(hora, sizeof(hora), "%H:%M", &amp;t);

  // Busca la proxima dosis del dia para mostrarla
  char prox[6] = "--:--";
  int ahora = t.tm_hour * 60 + t.tm_min;
  int mejor = 24 * 60 + 1;
  for (int i = 0; i &lt; N_DOSIS; i++) {
    int m = HORAS[i] * 60 + MINUTOS[i];
    if (m &gt;= ahora &amp;&amp; m &lt; mejor) {
      mejor = m;
      snprintf(prox, sizeof(prox), "%02d:%02d", HORAS[i], MINUTOS[i]);
    }
  }

  // Boton: dosis manual
  if (digitalRead(PIN_BTN) == LOW) {
    delay(30);
    if (digitalRead(PIN_BTN) == LOW) {
      dispensar("manual");
      while (digitalRead(PIN_BTN) == LOW) delay(10);
    }
  }

  // Dosis automatica si coincide hora y minuto (solo una vez por minuto)
  for (int i = 0; i &lt; N_DOSIS; i++) {
    if (t.tm_hour == HORAS[i] &amp;&amp; t.tm_min == MINUTOS[i] &amp;&amp; ultimaDosisMin != ahora) {
      dispensar("programada");
      ultimaDosisMin = ahora;
    }
  }

  pantalla(hora, prox);
  delay(300);
}`;
---
<ProjectLayout title="Stepper 05 · Dispensador Automático — ESP32" label="STEPPER 05" pageName="Dispensador Automático">
  <section class="section">
    <div class="section-label">Descripción</div>
    <div class="meta">
      <span class="badge avanzado">Avanzado</span>
      <span class="cat-tag">Motores · WiFi/NTP · OLED</span>
    </div>
    <p class="desc">
      Un dispensador de porciones (comida de mascotas, dulces o pastillas) que reparte solo a las
      <strong>horas que programes</strong>. El motor paso a paso gira un <strong>tambor o tornillo</strong>
      una fracción de vuelta para soltar una ración exacta. El ESP-32 obtiene la hora real por
      <strong>WiFi (NTP)</strong>, así que las dosis caen puntuales sin necesidad de un reloj externo. La
      <strong>OLED</strong> muestra la hora, la próxima dosis programada y cuántas raciones lleva servidas,
      y un <strong>botón</strong> permite dispensar una porción manual cuando quieras.
    </p>
  </section>

  <section class="section">
    <div class="section-label">Componentes</div>
    <div class="comp-list">
      <div class="comp-item"><div class="cdot"></div><span class="cname">ESP-32 Board</span><span class="cqty">1 PC</span></div>
      <div class="comp-item"><div class="cdot"></div><span class="cname">Stepper Motor 28BYJ-48</span><span class="cqty">1 PC</span></div>
      <div class="comp-item"><div class="cdot"></div><span class="cname">ULN2003 Driver Board</span><span class="cqty">1 PC</span></div>
      <div class="comp-item"><div class="cdot"></div><span class="cname">0.96" OLED Display (I2C)</span><span class="cqty">1 PC</span></div>
      <div class="comp-item"><div class="cdot"></div><span class="cname">Button (dosis manual)</span><span class="cqty">1 PC</span></div>
      <div class="comp-item"><div class="cdot"></div><span class="cname">Power Supply 5V externa (recomendada)</span><span class="cqty">1 PC</span></div>
      <div class="comp-item"><div class="cdot"></div><span class="cname">Protoboard + cables Dupont</span><span class="cqty">—</span></div>
    </div>
  </section>

  <section class="section">
    <div class="section-label">Conexiones</div>
    <table>
      <thead>
        <tr><th>Componente</th><th>Pin ESP-32</th><th>Notas</th></tr>
      </thead>
      <tbody>
        <tr><td>ULN2003 — IN1 / IN2 / IN3 / IN4</td><td><span class="pin">19 / 18 / 5 / 17</span></td><td>Bobinas del motor</td></tr>
        <tr><td>ULN2003 — VCC (+) / GND (−)</td><td><span class="pin">5V ext. / GND</span></td><td>Fuente externa, GND común</td></tr>
        <tr><td>OLED — SDA / SCL</td><td><span class="pin">21 / 22</span></td><td>Bus I2C (dirección 0x3C)</td></tr>
        <tr><td>OLED — VCC / GND</td><td><span class="pin">3.3V / GND</span></td><td>—</td></tr>
        <tr><td>Button — pata 1</td><td><span class="pin">GPIO 4</span></td><td>Usa INPUT_PULLUP interno</td></tr>
        <tr><td>Button — pata 2</td><td><span class="pin">GND</span></td><td>—</td></tr>
      </tbody>
    </table>
    <div class="note" style="margin-top:12px;">
      <strong>Mecánica:</strong> monta sobre el eje un tambor con compartimentos o un tornillo sinfín.
      Ajusta <code>PASOS_DOSIS</code> hasta que una vuelta parcial suelte la cantidad que quieres por ración.
    </div>
  </section>

  <section class="section">
    <div class="section-label">Código Arduino</div>
    <div class="code-box">
      <div class="code-header">
        <span class="code-lang">C++ / Arduino IDE (ESP-32)</span>
        <button class="copy-btn" id="copyBtn">Copiar</button>
      </div>
      <pre><code class="language-cpp" id="code" set:html={code}></code></pre>
    </div>
  </section>

  <section class="section">
    <div class="section-label">Cómo usar</div>
    <div class="steps">
      <div class="step"><div class="step-n">1</div><div class="step-text">Asegúrate de tener las librerías <code>Adafruit SSD1306</code> y <code>Adafruit GFX</code>. <code>WiFi.h</code>, <code>time.h</code> y <code>Stepper.h</code> ya vienen con el core del ESP-32.</div></div>
      <div class="step"><div class="step-n">2</div><div class="step-text">Edita <code>SSID</code> y <code>PASS</code> con tu red, y ajusta <code>GMT_OFFSET</code> a tu huso horario (en segundos: −5 h = <code>-5 * 3600</code>).</div></div>
      <div class="step"><div class="step-n">3</div><div class="step-text">Define tus horarios en los arreglos <code>HORAS[]</code> y <code>MINUTOS[]</code> (y <code>N_DOSIS</code> si cambias la cantidad).</div></div>
      <div class="step"><div class="step-n">4</div><div class="step-text">Calibra <code>PASOS_DOSIS</code>: súbelo o bájalo hasta que cada giro suelte una ración del tamaño deseado.</div></div>
      <div class="step"><div class="step-n">5</div><div class="step-text">Sube el código. La OLED mostrará la hora, la próxima dosis y el total de raciones. Pulsa el <strong>botón</strong> para una porción manual.</div></div>
    </div>
    <div class="note">
      <strong>Por qué NTP:</strong> el ESP-32 no tiene reloj con batería, así que al reiniciarse perdería la
      hora. Tomándola de internet con <code>configTime()</code> siempre está exacta. La variable
      <code>ultimaDosisMin</code> impide que, como el <code>loop()</code> corre varias veces por minuto, la
      dosis se repita una y otra vez durante ese minuto. <br /><br />
      <strong>Mejoras:</strong> añade un <strong>buzzer</strong> que avise al dispensar, o sube el conteo de
      raciones a internet. Si no quieres WiFi, puedes disparar las dosis con un <code>millis()</code> cada
      X horas, aunque perderías la precisión de la hora real.
    </div>
  </section>
</ProjectLayout>
