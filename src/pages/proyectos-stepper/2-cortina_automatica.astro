---
import ProjectLayout from '../../layouts/ProjectLayout.astro';
const code = String.raw`#include &lt;Stepper.h&gt;

const int STEPS_REV = 2048;     // 28BYJ-48: pasos por vuelta completa

#define IN1 19
#define IN2 18
#define IN3 5
#define IN4 17
#define PIN_LDR 35              // fotorresistor (divisor de voltaje)
#define PIN_BTN 4               // boton manual (a GND)

// El orden IN1, IN3, IN2, IN4 da la secuencia correcta del 28BYJ-48 con ULN2003
Stepper motor(STEPS_REV, IN1, IN3, IN2, IN4);

const long PASOS_RECORRIDO = 3L * STEPS_REV;  // 3 vueltas para abrir/cerrar del todo
const int  UMBRAL_DIA   = 2500;   // lectura MAYOR = hay luz de dia  -> abrir
const int  UMBRAL_NOCHE = 1200;   // lectura MENOR = es de noche     -> cerrar

bool abierta = false;            // la cortina arranca CERRADA

void apagarBobinas() {
  // Libera las bobinas: evita que el motor se caliente y consuma estando parado
  digitalWrite(IN1, LOW); digitalWrite(IN2, LOW);
  digitalWrite(IN3, LOW); digitalWrite(IN4, LOW);
}

void abrir() {
  if (abierta) return;
  Serial.println("Abriendo cortina...");
  motor.step(PASOS_RECORRIDO);
  abierta = true;
  apagarBobinas();
}

void cerrar() {
  if (!abierta) return;
  Serial.println("Cerrando cortina...");
  motor.step(-PASOS_RECORRIDO);
  abierta = false;
  apagarBobinas();
}

void setup() {
  Serial.begin(115200);
  pinMode(PIN_BTN, INPUT_PULLUP);
  motor.setSpeed(12);   // RPM
  Serial.println("Cortina automatica lista (inicia CERRADA).");
}

void loop() {
  // --- Boton: control manual (invierte el estado actual) ---
  if (digitalRead(PIN_BTN) == LOW) {
    delay(30);                                   // antirrebote
    if (digitalRead(PIN_BTN) == LOW) {
      if (abierta) cerrar(); else abrir();
      while (digitalRead(PIN_BTN) == LOW) delay(10);  // espera a que sueltes
    }
  }

  // --- Modo automatico por luz, con histeresis ---
  int luz = analogRead(PIN_LDR);
  if (luz &gt; UMBRAL_DIA &amp;&amp; !abierta)        abrir();
  else if (luz &lt; UMBRAL_NOCHE &amp;&amp; abierta)  cerrar();

  Serial.printf("Luz:%4d  Cortina:%s\n", luz, abierta ? "ABIERTA" : "CERRADA");
  delay(200);
}`;
---
<ProjectLayout title="Stepper 02 · Cortina Automática — ESP32" label="STEPPER 02" pageName="Cortina Automática">
  <section class="section">
    <div class="section-label">Descripción</div>
    <div class="meta">
      <span class="badge medio">Intermedio</span>
      <span class="cat-tag">Motores · Sensores · Stepper</span>
    </div>
    <p class="desc">
      Una cortina que se <strong>abre sola al amanecer y se cierra al anochecer</strong>. El motor
      paso a paso enrolla y desenrolla un hilo o varilla un número fijo de vueltas. Un
      <strong>fotorresistor (LDR)</strong> mide la luz del ambiente y decide cuándo actuar, usando
      <strong>histéresis</strong> (dos umbrales) para que no se quede abriendo y cerrando sin parar al
      atardecer. Además, un <strong>botón</strong> permite controlarla manualmente en cualquier momento.
    </p>
  </section>

  <section class="section">
    <div class="section-label">Componentes</div>
    <div class="comp-list">
      <div class="comp-item"><div class="cdot"></div><span class="cname">ESP-32 Board</span><span class="cqty">1 PC</span></div>
      <div class="comp-item"><div class="cdot"></div><span class="cname">Stepper Motor 28BYJ-48</span><span class="cqty">1 PC</span></div>
      <div class="comp-item"><div class="cdot"></div><span class="cname">ULN2003 Driver Board</span><span class="cqty">1 PC</span></div>
      <div class="comp-item"><div class="cdot"></div><span class="cname">Photoresistor (LDR)</span><span class="cqty">1 PC</span></div>
      <div class="comp-item"><div class="cdot"></div><span class="cname">Resistor 10K (divisor del LDR)</span><span class="cqty">1 PC</span></div>
      <div class="comp-item"><div class="cdot"></div><span class="cname">Button (control manual)</span><span class="cqty">1 PC</span></div>
      <div class="comp-item"><div class="cdot"></div><span class="cname">Power Supply 5V externa (recomendada)</span><span class="cqty">1 PC</span></div>
      <div class="comp-item"><div class="cdot"></div><span class="cname">Protoboard + cables Dupont</span><span class="cqty">—</span></div>
    </div>
  </section>

  <section class="section">
    <div class="section-label">Conexiones</div>
    <table>
      <thead>
        <tr><th>Componente</th><th>Pin ESP-32</th><th>Notas</th></tr>
      </thead>
      <tbody>
        <tr><td>ULN2003 — IN1</td><td><span class="pin">GPIO 19</span></td><td>Bobina 1</td></tr>
        <tr><td>ULN2003 — IN2</td><td><span class="pin">GPIO 18</span></td><td>Bobina 2</td></tr>
        <tr><td>ULN2003 — IN3</td><td><span class="pin">GPIO 5</span></td><td>Bobina 3</td></tr>
        <tr><td>ULN2003 — IN4</td><td><span class="pin">GPIO 17</span></td><td>Bobina 4</td></tr>
        <tr><td>ULN2003 — VCC (+)</td><td><span class="pin">5V ext.</span></td><td>Usa la fuente externa, NO el 5V del ESP-32</td></tr>
        <tr><td>ULN2003 — GND (−)</td><td><span class="pin">GND</span></td><td>GND común con ESP-32 y fuente</td></tr>
        <tr><td>LDR — extremo A</td><td><span class="pin">3.3V</span></td><td>El otro extremo va al nodo central</td></tr>
        <tr><td>LDR — nodo + Resistor 10K</td><td><span class="pin">GPIO 35</span></td><td>Nodo entre LDR y resistencia (la resistencia va a GND)</td></tr>
        <tr><td>Button — pata 1</td><td><span class="pin">GPIO 4</span></td><td>Usa INPUT_PULLUP interno</td></tr>
        <tr><td>Button — pata 2</td><td><span class="pin">GND</span></td><td>—</td></tr>
      </tbody>
    </table>
    <div class="note" style="margin-top:12px;">
      <strong>Divisor del LDR:</strong> conecta el LDR entre <code>3.3V</code> y el pin <code>GPIO 35</code>,
      y la resistencia de <code>10K</code> entre <code>GPIO 35</code> y <code>GND</code>. Así, con más luz
      la lectura <strong>sube</strong>. Si en tu montaje resulta al revés, intercambia el LDR y la resistencia.
    </div>
  </section>

  <section class="section">
    <div class="section-label">Código Arduino</div>
    <div class="code-box">
      <div class="code-header">
        <span class="code-lang">C++ / Arduino IDE (ESP-32)</span>
        <button class="copy-btn" id="copyBtn">Copiar</button>
      </div>
      <pre><code class="language-cpp" id="code" set:html={code}></code></pre>
    </div>
  </section>

  <section class="section">
    <div class="section-label">Cómo usar</div>
    <div class="steps">
      <div class="step"><div class="step-n">1</div><div class="step-text">La librería <code>Stepper.h</code> ya viene con el IDE de Arduino. No instales nada extra.</div></div>
      <div class="step"><div class="step-n">2</div><div class="step-text">Arma el divisor del LDR (LDR a 3.3V, resistencia de 10K a GND, el nodo a <code>GPIO 35</code>) y el botón entre <code>GPIO 4</code> y GND.</div></div>
      <div class="step"><div class="step-n">3</div><div class="step-text">Deja la cortina <strong>físicamente cerrada</strong> antes de encender, porque el código asume que arranca cerrada (el motor no tiene sensor de posición).</div></div>
      <div class="step"><div class="step-n">4</div><div class="step-text">Sube el código y abre el <strong>Monitor Serie</strong> a 115200. Tapa el LDR con la mano (simula la noche) y luego ilumínalo: la cortina cerrará y abrirá sola.</div></div>
      <div class="step"><div class="step-n">5</div><div class="step-text">Pulsa el <strong>botón</strong> para abrir o cerrar manualmente en cualquier momento.</div></div>
    </div>
    <div class="note">
      <strong>Calibra los umbrales:</strong> mira los valores de <code>Luz:</code> en el Monitor Serie con tu
      iluminación real y ajusta <code>UMBRAL_DIA</code> y <code>UMBRAL_NOCHE</code>. La separación entre
      ambos es la histéresis: cuanto mayor sea, menos se "duda" la cortina al atardecer. <br /><br />
      <strong>Ajusta el recorrido:</strong> cambia <code>PASOS_RECORRIDO</code> (más vueltas = más tela).
      Si la cortina sube cuando debería bajar, invierte el signo en <code>motor.step()</code> o intercambia
      <code>IN2</code> e <code>IN3</code>. Como mejora, añade la <strong>OLED</strong> para mostrar el estado
      y el nivel de luz, o un <strong>horario por NTP</strong> en vez del LDR.
    </div>
  </section>
</ProjectLayout>
