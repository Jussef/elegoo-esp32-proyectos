---
import ProjectLayout from '../../layouts/ProjectLayout.astro';
const code = String.raw`#include &lt;Wire.h&gt;
#include &lt;ESP32Servo.h&gt;
#include &lt;math.h&gt;

#define MPU_ADDR  0x68
#define SERVO_PIN 13

Servo servo;

void mpuInit() {
  Wire.beginTransmission(MPU_ADDR);
  Wire.write(0x6B);
  Wire.write(0x00);   // Despertar el sensor
  Wire.endTransmission(true);
}

void readAccel(float &amp;ax, float &amp;ay, float &amp;az) {
  Wire.beginTransmission(MPU_ADDR);
  Wire.write(0x3B);
  Wire.endTransmission(false);
  Wire.requestFrom(MPU_ADDR, 6, true);

  uint8_t d[6];
  for (int i = 0; i &lt; 6; i++) d[i] = Wire.read();

  ax = (int16_t)(d[0] &lt;&lt; 8 | d[1]) / 16384.0f;
  ay = (int16_t)(d[2] &lt;&lt; 8 | d[3]) / 16384.0f;
  az = (int16_t)(d[4] &lt;&lt; 8 | d[5]) / 16384.0f;
}

void setup() {
  Serial.begin(115200);
  Wire.begin();
  mpuInit();

  servo.attach(SERVO_PIN);
  servo.write(90);   // Centro al arrancar
  delay(600);

  Serial.println("Gimbal listo. Inclina el modulo para mover el servo.");
}

void loop() {
  float ax, ay, az;
  readAccel(ax, ay, az);

  // Calcula el angulo de roll con filtro paso-bajo
  static float rf = 0.0f;
  float roll = atan2f(ay, sqrtf(ax*ax + az*az)) * 180.0f / M_PI;
  rf = rf * 0.80f + roll * 0.20f;

  // Mapea -45..+45 grados de inclinacion a 45..135 grados del servo (centro = 90)
  float angulo = 90.0f + constrain(rf, -45.0f, 45.0f);
  servo.write((int)angulo);

  Serial.printf("Roll: %+.1f  Servo: %d\n", rf, (int)angulo);
  delay(20);
}`;
---
<ProjectLayout title="GY-6500 01 · Gimbal Simple — ESP32" label="GY-6500 01" pageName="Gimbal Simple">
  <section class="section">
    <div class="section-label">Descripción</div>
    <div class="meta">
      <span class="badge avanzado">Avanzado</span>
      <span class="cat-tag">Sensores · Servos · I2C</span>
    </div>
    <p class="desc">
      Un gimbal de un eje: el servo SG90 mantiene una plataforma horizontal aunque inclines
      el protoboard. El GY-6500 (MPU-6050) mide el ángulo de Roll en tiempo real y el ESP-32
      ajusta el servo en sentido contrario para compensar. Un filtro paso-bajo suaviza las lecturas
      del acelerómetro para que el movimiento sea fluido. Base para construir estabilizadores de cámara.
    </p>
  </section>

  <section class="section">
    <div class="section-label">Componentes</div>
    <div class="comp-list">
      <div class="comp-item"><div class="cdot"></div><span class="cname">ESP-32 Board</span><span class="cqty">1 PC</span></div>
      <div class="comp-item"><div class="cdot"></div><span class="cname">GY-6500 Module (MPU-6050)</span><span class="cqty">1 PC</span></div>
      <div class="comp-item"><div class="cdot"></div><span class="cname">Servo SG90</span><span class="cqty">1 PC</span></div>
      <div class="comp-item"><div class="cdot"></div><span class="cname">Power Supply 5V externa</span><span class="cqty">1 PC</span></div>
      <div class="comp-item"><div class="cdot"></div><span class="cname">Protoboard + cables</span><span class="cqty">—</span></div>
    </div>
  </section>

  <section class="section">
    <div class="section-label">Conexiones</div>
    <table>
      <thead>
        <tr><th>Componente</th><th>Pin ESP-32</th><th>Notas</th></tr>
      </thead>
      <tbody>
        <tr><td>GY-6500 — SDA</td><td><span class="pin">GPIO 21</span></td><td>I2C datos</td></tr>
        <tr><td>GY-6500 — SCL</td><td><span class="pin">GPIO 22</span></td><td>I2C reloj</td></tr>
        <tr><td>GY-6500 — VCC</td><td><span class="pin">3.3V</span></td><td>—</td></tr>
        <tr><td>GY-6500 — GND</td><td><span class="pin">GND</span></td><td>—</td></tr>
        <tr><td>Servo — Señal</td><td><span class="pin">GPIO 13</span></td><td>Cable naranja/amarillo</td></tr>
        <tr><td>Servo — VCC</td><td><span class="pin">5V ext.</span></td><td>Alimentar desde fuente externa, no desde el ESP-32</td></tr>
        <tr><td>Servo — GND</td><td><span class="pin">GND</span></td><td>GND común con ESP-32 y fuente</td></tr>
      </tbody>
    </table>
    <div class="note" style="margin-top:12px;">
      <strong>Alimentación del servo:</strong> El SG90 bajo carga consume hasta 700 mA en picos.
      Conéctalo a la fuente de 5V externa para evitar que el ESP-32 se resetee.
      Comparte el GND entre la fuente, el servo y el ESP-32.
    </div>
  </section>

  <section class="section">
    <div class="section-label">Código Arduino</div>
    <div class="code-box">
      <div class="code-header">
        <span class="code-lang">C++ / Arduino IDE (ESP-32)</span>
        <button class="copy-btn" id="copyBtn">Copiar</button>
      </div>
      <pre><code class="language-cpp" id="code" set:html={code}></code></pre>
    </div>
  </section>

  <section class="section">
    <div class="section-label">Cómo usar</div>
    <div class="steps">
      <div class="step"><div class="step-n">1</div><div class="step-text">Instala la librería <code>ESP32Servo</code> desde el Gestor de Librerías de Arduino IDE. No necesitas ninguna librería adicional para el GY-6500.</div></div>
      <div class="step"><div class="step-n">2</div><div class="step-text">Conecta el GY-6500 por I2C (pines 21/22) y el servo con su señal en <code>GPIO 13</code>. El VCC del servo va a la fuente de 5V externa.</div></div>
      <div class="step"><div class="step-n">3</div><div class="step-text">Sube el código. El servo se centrará en 90° al encender. Inclina el protoboard y verás el servo moverse para compensar.</div></div>
      <div class="step"><div class="step-n">4</div><div class="step-text">Monta una pequeña plataforma sobre el eje del servo para ver el efecto de estabilización en tiempo real.</div></div>
      <div class="step"><div class="step-n">5</div><div class="step-text">Abre el Monitor Serie a 115200 baud para ver el ángulo de Roll y la posición del servo en cada iteración.</div></div>
    </div>
    <div class="note">
      <strong>Ajuste del filtro:</strong> el valor <code>0.80f</code> del filtro paso-bajo controla la
      suavidad del movimiento. Un valor más cercano a 1.0 hace la respuesta más lenta y suave;
      más cercano a 0.5 la hace más rápida pero más nerviosa. Para un gimbal real conviene usar
      un filtro complementario o un PID.
    </div>
  </section>
</ProjectLayout>
