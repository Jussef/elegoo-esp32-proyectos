---
import ProjectLayout from '../../layouts/ProjectLayout.astro';
const code = String.raw`#include &lt;Wire.h&gt;
#include &lt;math.h&gt;

#define MPU_ADDR 0x68

// Pines LED RGB (catodo comun)
#define PIN_R 25
#define PIN_G 26
#define PIN_B 27

void mpuInit() {
  Wire.beginTransmission(MPU_ADDR);
  Wire.write(0x6B);
  Wire.write(0x00);
  Wire.endTransmission(true);
}

void readAccel(float &amp;ax, float &amp;ay, float &amp;az) {
  Wire.beginTransmission(MPU_ADDR);
  Wire.write(0x3B);
  Wire.endTransmission(false);
  Wire.requestFrom(MPU_ADDR, 6, true);

  uint8_t d[6];
  for (int i = 0; i &lt; 6; i++) d[i] = Wire.read();

  ax = (int16_t)(d[0] &lt;&lt; 8 | d[1]) / 16384.0f;
  ay = (int16_t)(d[2] &lt;&lt; 8 | d[3]) / 16384.0f;
  az = (int16_t)(d[4] &lt;&lt; 8 | d[5]) / 16384.0f;
}

void setup() {
  Serial.begin(115200);
  Wire.begin();
  mpuInit();

  // Configuracion PWM para cada canal del LED RGB
  ledcSetup(0, 5000, 8);   // canal 0 - Rojo
  ledcSetup(1, 5000, 8);   // canal 1 - Verde
  ledcSetup(2, 5000, 8);   // canal 2 - Azul
  ledcAttachPin(PIN_R, 0);
  ledcAttachPin(PIN_G, 1);
  ledcAttachPin(PIN_B, 2);

  Serial.println("Controlador de gestos listo.");
}

void loop() {
  float ax, ay, az;
  readAccel(ax, ay, az);

  // Filtro paso-bajo
  static float pf = 0.0f, rf = 0.0f;
  float pitch = atan2f(ax, sqrtf(ay*ay + az*az)) * 180.0f / M_PI;
  float roll  = atan2f(ay, sqrtf(ax*ax + az*az)) * 180.0f / M_PI;
  pf = pf * 0.80f + pitch * 0.20f;
  rf = rf * 0.80f + roll  * 0.20f;

  // Mapea angulo (0-90 grados) a brillo (0-255)
  int r = (int)map((long)constrain(fabsf(pf), 0.0f, 90.0f), 0, 90, 0, 255);
  int g = (int)map((long)constrain(fabsf(rf), 0.0f, 90.0f), 0, 90, 0, 255);
  int b = 255 - max(r, g);   // azul: mas intenso cuando esta nivelado

  ledcWrite(0, r);
  ledcWrite(1, g);
  ledcWrite(2, b);

  Serial.printf("Pitch:%+.1f  Roll:%+.1f  R:%d G:%d B:%d\n", pf, rf, r, g, b);
  delay(30);
}`;
---
<ProjectLayout title="GY-6500 02 · Controlador de Gestos — ESP32" label="GY-6500 02" pageName="Controlador de Gestos">
  <section class="section">
    <div class="section-label">Descripción</div>
    <div class="meta">
      <span class="badge medio">Intermedio</span>
      <span class="cat-tag">Sensores · LED RGB · I2C</span>
    </div>
    <p class="desc">
      El GY-6500 (MPU-6050) detecta la inclinación en dos ejes y la convierte en color.
      Inclinar hacia adelante aumenta el rojo, inclinar hacia un lado aumenta el verde,
      y cuando el dispositivo está nivelado el LED brilla en azul. Todo el control se hace
      con los gestos de tu mano, sin botones.
    </p>
  </section>

  <section class="section">
    <div class="section-label">Componentes</div>
    <div class="comp-list">
      <div class="comp-item"><div class="cdot"></div><span class="cname">ESP-32 Board</span><span class="cqty">1 PC</span></div>
      <div class="comp-item"><div class="cdot"></div><span class="cname">GY-6500 Module (MPU-6050)</span><span class="cqty">1 PC</span></div>
      <div class="comp-item"><div class="cdot"></div><span class="cname">LED RGB (cátodo común)</span><span class="cqty">1 PC</span></div>
      <div class="comp-item"><div class="cdot"></div><span class="cname">Resistencias 220Ω</span><span class="cqty">3 PCS</span></div>
      <div class="comp-item"><div class="cdot"></div><span class="cname">Protoboard</span><span class="cqty">—</span></div>
    </div>
  </section>

  <section class="section">
    <div class="section-label">Conexiones</div>
    <table>
      <thead>
        <tr><th>Componente</th><th>Pin ESP-32</th><th>Notas</th></tr>
      </thead>
      <tbody>
        <tr><td>GY-6500 — SDA</td><td><span class="pin">GPIO 21</span></td><td>I2C datos</td></tr>
        <tr><td>GY-6500 — SCL</td><td><span class="pin">GPIO 22</span></td><td>I2C reloj</td></tr>
        <tr><td>GY-6500 — VCC</td><td><span class="pin">3.3V</span></td><td>—</td></tr>
        <tr><td>GY-6500 — GND</td><td><span class="pin">GND</span></td><td>—</td></tr>
        <tr><td>LED R — vía resistor 220Ω</td><td><span class="pin">GPIO 25</span></td><td>Canal Rojo (PWM)</td></tr>
        <tr><td>LED G — vía resistor 220Ω</td><td><span class="pin">GPIO 26</span></td><td>Canal Verde (PWM)</td></tr>
        <tr><td>LED B — vía resistor 220Ω</td><td><span class="pin">GPIO 27</span></td><td>Canal Azul (PWM)</td></tr>
        <tr><td>LED Cátodo (−)</td><td><span class="pin">GND</span></td><td>Pata más larga del LED (cátodo común)</td></tr>
      </tbody>
    </table>
    <div class="note" style="margin-top:12px;">
      <strong>LED de ánodo común:</strong> Si tu LED RGB es de ánodo común (pata larga a 3.3V), conecta el común a 3.3V y lógica invierte: <code>ledcWrite(canal, 255 - valor)</code>. El código actual funciona para cátodo común.
    </div>
  </section>

  <section class="section">
    <div class="section-label">Código Arduino</div>
    <div class="code-box">
      <div class="code-header">
        <span class="code-lang">C++ / Arduino IDE (ESP-32)</span>
        <button class="copy-btn" id="copyBtn">Copiar</button>
      </div>
      <pre><code class="language-cpp" id="code" set:html={code}></code></pre>
    </div>
  </section>

  <section class="section">
    <div class="section-label">Cómo usar</div>
    <div class="steps">
      <div class="step"><div class="step-n">1</div><div class="step-text">No necesitas instalar librerías extra. <code>Wire.h</code> ya viene con el core del ESP-32. El GY-6500 se lee directamente por I2C.</div></div>
      <div class="step"><div class="step-n">2</div><div class="step-text">Conecta el GY-6500 por I2C y el LED RGB con sus tres resistencias según la tabla.</div></div>
      <div class="step"><div class="step-n">3</div><div class="step-text">Sube el código. Sostén el protoboard horizontalmente: el LED brillará en <strong>azul</strong> (nivelado).</div></div>
      <div class="step"><div class="step-n">4</div><div class="step-text">Inclina hacia ti: el LED se vuelve más <strong>rojo</strong>. Inclina a los lados: el LED se vuelve más <strong>verde</strong>.</div></div>
      <div class="step"><div class="step-n">5</div><div class="step-text">Abre el Monitor Serie a 115200 para ver los ángulos Pitch/Roll y los valores R/G/B en tiempo real.</div></div>
    </div>
    <div class="note">
      <strong>Personalización:</strong> puedes cambiar el mapeo de gestos a cualquier salida: velocidad de un motor,
      posición de un servo, volumen de audio. El núcleo es siempre el mismo: leer el eje → filtrar → mapear a rango de salida.
    </div>
  </section>
</ProjectLayout>
