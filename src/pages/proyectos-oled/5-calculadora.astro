---
import ProjectLayout from '../../layouts/ProjectLayout.astro';
const code = String.raw`#include &lt;Wire.h&gt;
#include &lt;Adafruit_GFX.h&gt;
#include &lt;Adafruit_SSD1306.h&gt;
#include &lt;Keypad.h&gt;
#include &lt;math.h&gt;

#define SCREEN_W   128
#define SCREEN_H    64
#define OLED_RESET  -1

const byte KROWS = 4, KCOLS = 4;
char keys[KROWS][KCOLS] = {
  {'1','2','3','A'},
  {'4','5','6','B'},
  {'7','8','9','C'},
  {'*','0','#','D'}
};
byte rowPins[KROWS] = {13, 14, 27, 26};
byte colPins[KCOLS] = {25, 33, 32,  4};

Keypad           keypad = Keypad(makeKeymap(keys), rowPins, colPins, KROWS, KCOLS);
Adafruit_SSD1306 oled(SCREEN_W, SCREEN_H, &amp;Wire, OLED_RESET);

String currentInput = "0";
String displayVal   = "0";
String exprLine     = "";
float  op1          = 0;
char   pendingOp    = 0;
bool   freshInput   = true;

// Convierte float a String eliminando decimales innecesarios
String fmtNum(float v) {
  if (!isfinite(v)) return "Error";
  if (v == (float)(long)v &amp;&amp; fabsf(v) &lt; 1e9f) return String((long)v);
  String s = String(v, 4);
  while (s.indexOf('.') &gt;= 0 &amp;&amp; s.endsWith("0")) s.remove(s.length() - 1);
  if (s.endsWith(".")) s.remove(s.length() - 1);
  return s;
}

String opSym(char op) { return (op == '*') ? "x" : String(op); }

void showOLED() {
  oled.clearDisplay();

  // Linea de expresion (arriba, texto pequeno)
  oled.setTextSize(1);
  oled.setCursor(2, 2);
  String expr = (exprLine.length() &gt; 21) ? exprLine.substring(exprLine.length() - 21) : exprLine;
  oled.print(expr);
  oled.drawLine(0, 13, 127, 13, SSD1306_WHITE);

  // Valor actual (abajo, texto grande y centrado)
  int tsize = (displayVal.length() &lt;= 5) ? 3 : (displayVal.length() &lt;= 9) ? 2 : 1;
  int tw    = displayVal.length() * 6 * tsize;
  int textH = 8 * tsize;
  int cx    = max(2, (128 - tw) / 2);
  int cy    = 14 + (50 - textH) / 2;
  oled.setTextSize(tsize);
  oled.setCursor(cx, cy);
  oled.print(displayVal);

  oled.display();
}

void handleKey(char key) {
  if (key &gt;= '0' &amp;&amp; key &lt;= '9') {
    if (freshInput || currentInput == "0") {
      currentInput = (key == '0') ? "0" : String(key);
      freshInput = false;
    } else if (currentInput.length() &lt; 11) {
      currentInput += key;
    }
    displayVal = currentInput;
    exprLine = pendingOp ? (fmtNum(op1) + " " + opSym(pendingOp) + " " + currentInput)
                         : currentInput;

  } else if (key == 'A' || key == 'B' || key == 'C' || key == 'D') {
    char ops[] = {'+', '-', '*', '/'};
    op1          = currentInput.toFloat();
    pendingOp    = ops[key - 'A'];
    freshInput   = true;
    currentInput = "0";
    displayVal   = "0";
    exprLine     = fmtNum(op1) + " " + opSym(pendingOp);

  } else if (key == '#') {  // Igual =
    if (pendingOp &amp;&amp; !freshInput) {
      float op2 = currentInput.toFloat();
      float res;
      switch (pendingOp) {
        case '+': res = op1 + op2; break;
        case '-': res = op1 - op2; break;
        case '*': res = op1 * op2; break;
        case '/': res = (op2 != 0.0f) ? op1 / op2 : NAN; break;
        default:  res = op2;
      }
      exprLine   = fmtNum(op1) + " " + opSym(pendingOp) + " " + fmtNum(op2) + " =";
      displayVal = isfinite(res) ? fmtNum(res) : "Error /0";
      if (isfinite(res)) { op1 = res; currentInput = displayVal; }
      pendingOp  = 0;
      freshInput = true;
    }

  } else if (key == '*') {  // C = Borrar
    currentInput = "0"; displayVal = "0"; exprLine = "";
    op1 = 0; pendingOp = 0; freshInput = true;
  }

  showOLED();
}

void setup() {
  Serial.begin(115200);
  if (!oled.begin(SSD1306_SWITCHCAPVCC, 0x3C)) {
    Serial.println("Error: OLED no encontrado");
    while (true);
  }
  oled.setTextColor(SSD1306_WHITE);
  showOLED();
}

void loop() {
  char key = keypad.getKey();
  if (key) {
    Serial.print("Tecla: "); Serial.println(key);
    handleKey(key);
  }
}`;
---
<ProjectLayout title="OLED 05 · Calculadora — ESP32" label="OLED 05" pageName="Calculadora">
  <section class="section">
    <div class="section-label">Descripción</div>
    <div class="meta">
      <span class="badge medio">Intermedio</span>
      <span class="cat-tag">Pantallas · Control</span>
    </div>
    <p class="desc">
      Calculadora funcional de 4 operaciones usando el teclado matricial 4×4 y la pantalla OLED.
      La línea superior muestra la expresión en curso y la zona inferior muestra el número actual
      en tamaño grande. Soporta encadenamiento de operaciones, números decimales y detecta
      la división por cero.
    </p>
  </section>

  <section class="section">
    <div class="section-label">Mapa del teclado</div>
    <div class="keymap">
      <div class="kkey"><div class="klabel">1</div><div class="kfunc">1</div></div>
      <div class="kkey"><div class="klabel">2</div><div class="kfunc">2</div></div>
      <div class="kkey"><div class="klabel">3</div><div class="kfunc">3</div></div>
      <div class="kkey kop"><div class="klabel">A</div><div class="kfunc">Suma +</div></div>
      <div class="kkey"><div class="klabel">4</div><div class="kfunc">4</div></div>
      <div class="kkey"><div class="klabel">5</div><div class="kfunc">5</div></div>
      <div class="kkey"><div class="klabel">6</div><div class="kfunc">6</div></div>
      <div class="kkey kop"><div class="klabel">B</div><div class="kfunc">Resta −</div></div>
      <div class="kkey"><div class="klabel">7</div><div class="kfunc">7</div></div>
      <div class="kkey"><div class="klabel">8</div><div class="kfunc">8</div></div>
      <div class="kkey"><div class="klabel">9</div><div class="kfunc">9</div></div>
      <div class="kkey kop"><div class="klabel">C</div><div class="kfunc">Mult ×</div></div>
      <div class="kkey kspecial"><div class="klabel">*</div><div class="kfunc">Borrar C</div></div>
      <div class="kkey"><div class="klabel">0</div><div class="kfunc">0</div></div>
      <div class="kkey kop"><div class="klabel">#</div><div class="kfunc">Igual =</div></div>
      <div class="kkey kop"><div class="klabel">D</div><div class="kfunc">Div ÷</div></div>
    </div>
  </section>

  <section class="section">
    <div class="section-label">Componentes</div>
    <div class="comp-list">
      <div class="comp-item"><div class="cdot"></div><span class="cname">ESP-32 Board</span><span class="cqty">1 PC</span></div>
      <div class="comp-item"><div class="cdot"></div><span class="cname">0.96" OLED Display (I2C)</span><span class="cqty">1 PC</span></div>
      <div class="comp-item"><div class="cdot"></div><span class="cname">Membrane Switch Module (4×4)</span><span class="cqty">1 PC</span></div>
      <div class="comp-item"><div class="cdot"></div><span class="cname">Protoboard + cables Dupont</span><span class="cqty">—</span></div>
    </div>
  </section>

  <section class="section">
    <div class="section-label">Conexiones</div>
    <table>
      <thead>
        <tr><th>Componente</th><th>Pin ESP-32</th><th>Notas</th></tr>
      </thead>
      <tbody>
        <tr><td>OLED — SDA</td><td><span class="pin">GPIO 21</span></td><td>I2C datos</td></tr>
        <tr><td>OLED — SCL</td><td><span class="pin">GPIO 22</span></td><td>I2C reloj</td></tr>
        <tr><td>OLED — VCC</td><td><span class="pin">3.3V</span></td><td>—</td></tr>
        <tr><td>OLED — GND</td><td><span class="pin">GND</span></td><td>—</td></tr>
        <tr><td>Keypad pin 1 — Fila 1</td><td><span class="pin">GPIO 13</span></td><td>Fila 1,2,3,A</td></tr>
        <tr><td>Keypad pin 2 — Fila 2</td><td><span class="pin">GPIO 14</span></td><td>Fila 4,5,6,B</td></tr>
        <tr><td>Keypad pin 3 — Fila 3</td><td><span class="pin">GPIO 27</span></td><td>Fila 7,8,9,C</td></tr>
        <tr><td>Keypad pin 4 — Fila 4</td><td><span class="pin">GPIO 26</span></td><td>Fila *,0,#,D</td></tr>
        <tr><td>Keypad pin 5 — Col 1</td><td><span class="pin">GPIO 25</span></td><td>Col 1,4,7,*</td></tr>
        <tr><td>Keypad pin 6 — Col 2</td><td><span class="pin">GPIO 33</span></td><td>Col 2,5,8,0</td></tr>
        <tr><td>Keypad pin 7 — Col 3</td><td><span class="pin">GPIO 32</span></td><td>Col 3,6,9,#</td></tr>
        <tr><td>Keypad pin 8 — Col 4</td><td><span class="pin">GPIO 4</span></td><td>Col A,B,C,D</td></tr>
      </tbody>
    </table>
    <div class="note" style="margin-top:12px;">
      <strong>Pines del keypad:</strong> El conector tiene 8 pines en cinta. Contados desde el lado izquierdo
      del módulo: pines 1–4 son filas (arriba → abajo) y pines 5–8 son columnas (izquierda → derecha).
    </div>
  </section>

  <section class="section">
    <div class="section-label">Código Arduino</div>
    <div class="code-box">
      <div class="code-header">
        <span class="code-lang">C++ / Arduino IDE (ESP-32)</span>
        <button class="copy-btn" id="copyBtn">Copiar</button>
      </div>
      <pre><code class="language-cpp" id="code" set:html={code}></code></pre>
    </div>
  </section>

  <section class="section">
    <div class="section-label">Cómo usar</div>
    <div class="steps">
      <div class="step"><div class="step-n">1</div><div class="step-text">Instala <code>Adafruit SSD1306</code> y la librería <code>Keypad</code> de <em>Mark Stanley &amp; Alexander Brevig</em> desde el Gestor de Librerías de Arduino IDE.</div></div>
      <div class="step"><div class="step-n">2</div><div class="step-text">Conecta el OLED por I2C (pines 21/22) y el teclado matricial según la tabla. El conector del keypad tiene 8 pines; conecta en orden de izquierda a derecha.</div></div>
      <div class="step"><div class="step-n">3</div><div class="step-text">Sube el código. La pantalla muestra <strong>0</strong> listo para ingresar el primer número.</div></div>
      <div class="step"><div class="step-n">4</div><div class="step-text">Escribe un número, presiona <strong>A/B/C/D</strong> para elegir operación, escribe el segundo número y presiona <strong>#</strong> para ver el resultado.</div></div>
      <div class="step"><div class="step-n">5</div><div class="step-text">Presiona <strong>*</strong> en cualquier momento para borrar y empezar de nuevo. Puedes encadenar operaciones: resultado → operador → número → igual.</div></div>
    </div>
    <div class="note">
      <strong>Tip:</strong> Si alguna tecla no responde, verifica el orden de los pines en el conector del keypad.
      Puedes usar el Monitor Serie (115200 baud) para ver qué tecla detecta el código con cada pulsación
      y así diagnosticar problemas de cableado.
    </div>
  </section>
</ProjectLayout>

<style is:global>
.keymap { display: grid; grid-template-columns: repeat(4, 1fr); gap: 6px; max-width: 320px; }
.kkey { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; padding: 8px 4px; text-align: center; }
.kkey .klabel { font-size: 15px; font-weight: 700; color: #22d3ee; font-family: monospace; }
.kkey .kfunc { font-size: 10px; color: rgba(255,255,255,0.4); margin-top: 3px; }
.kkey.kop .klabel { color: #fcd34d; }
.kkey.kspecial .klabel { color: #fca5a5; }
</style>
