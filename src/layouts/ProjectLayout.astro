---
interface Props {
  title: string;
  label: string;
  pageName: string;
  backUrl?: string;
}
const { title, label, pageName, backUrl = "/" } = Astro.props;
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/atom-one-dark.min.css">
</head>
<body>

<header>
  <div class="header-inner">
    <a class="back" href={backUrl}>← Volver</a>
    <span class="hdiv">/</span>
    <span class="proj-num">{label}</span>
    <span class="hdiv">/</span>
    <span class="proj-title">{pageName}</span>
  </div>
</header>

<main>
  <slot />
</main>

<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
<script is:inline>
(function () {
  var el = document.getElementById('code');
  if (el && typeof hljs !== 'undefined') hljs.highlightElement(el);
  var btn = document.getElementById('copyBtn');
  if (btn && el) {
    btn.addEventListener('click', function () {
      navigator.clipboard.writeText(el.textContent).then(() => {
        this.textContent = '✓ Copiado';
        setTimeout(() => this.textContent = 'Copiar', 2000);
      });
    });
  }
})();
</script>

</body>
</html>

<style is:global>
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: 'Segoe UI', system-ui, sans-serif; background: #0f0f13; color: #fff; min-height: 100vh; }
header { border-bottom: 1px solid rgba(255,255,255,0.08); padding: 14px 24px; position: sticky; top: 0; background: #0f0f13; z-index: 10; }
.header-inner { max-width: 820px; margin: 0 auto; display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
.back { color: rgba(255,255,255,0.4); text-decoration: none; font-size: 13px; }
.back:hover { color: #22d3ee; }
.hdiv { color: rgba(255,255,255,0.15); }
.proj-num { font-size: 11px; font-weight: 700; color: rgba(34,211,238,0.55); letter-spacing: 0.05em; }
.proj-title { font-size: 15px; font-weight: 700; }
main { max-width: 820px; margin: 0 auto; padding: 28px 24px; display: flex; flex-direction: column; gap: 18px; }
.section { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 16px; padding: 22px 24px; }
.section-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(34,211,238,0.6); margin-bottom: 14px; }
.meta { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; margin-bottom: 12px; }
.badge { display: inline-block; font-size: 11px; font-weight: 600; padding: 4px 10px; border-radius: 999px; }
.facil { background: rgba(16,185,129,0.12); color: #6ee7b7; border: 1px solid rgba(16,185,129,0.2); }
.medio { background: rgba(245,158,11,0.12); color: #fcd34d; border: 1px solid rgba(245,158,11,0.2); }
.avanzado { background: rgba(239,68,68,0.12); color: #fca5a5; border: 1px solid rgba(239,68,68,0.2); }
.demo { background: rgba(34,211,238,0.12); color: #67e8f9; border: 1px solid rgba(34,211,238,0.25); }
.cat-tag { font-size: 11px; color: rgba(255,255,255,0.35); padding: 4px 10px; border-radius: 999px; border: 1px solid rgba(255,255,255,0.1); }
.desc { font-size: 14px; color: rgba(255,255,255,0.7); line-height: 1.7; }
.comp-list { display: flex; flex-direction: column; gap: 9px; }
.comp-item { display: flex; align-items: center; gap: 12px; font-size: 13px; }
.cdot { width: 5px; height: 5px; border-radius: 50%; background: #22d3ee; flex-shrink: 0; }
.cname { color: rgba(255,255,255,0.8); }
.cqty { margin-left: auto; font-size: 11px; color: rgba(255,255,255,0.28); }
table { width: 100%; border-collapse: collapse; font-size: 13px; }
th { text-align: left; padding: 8px 12px; font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: rgba(255,255,255,0.35); border-bottom: 1px solid rgba(255,255,255,0.08); }
td { padding: 10px 12px; border-bottom: 1px solid rgba(255,255,255,0.04); color: rgba(255,255,255,0.7); vertical-align: middle; }
tr:last-child td { border-bottom: none; }
.pin { font-family: 'Courier New', monospace; font-size: 12px; background: rgba(34,211,238,0.08); color: #22d3ee; padding: 2px 8px; border-radius: 5px; border: 1px solid rgba(34,211,238,0.15); white-space: nowrap; }
.no-wiring { font-size: 13px; color: rgba(255,255,255,0.4); font-style: italic; }
.code-box { background: #0a0a10; border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; overflow: hidden; }
.code-header { padding: 10px 16px; border-bottom: 1px solid rgba(255,255,255,0.06); display: flex; justify-content: space-between; align-items: center; }
.code-lang { font-size: 11px; color: rgba(255,255,255,0.25); font-family: monospace; }
.copy-btn { font-size: 11px; color: rgba(34,211,238,0.6); background: none; border: 1px solid rgba(34,211,238,0.15); border-radius: 5px; padding: 3px 10px; cursor: pointer; transition: .15s; }
.copy-btn:hover { background: rgba(34,211,238,0.08); color: #22d3ee; }
pre { margin: 0 !important; border-radius: 0 !important; background: #0a0a10 !important; overflow-x: auto; }
pre code { display: block; padding: 18px 20px; font-size: 12.5px; line-height: 1.6; color: #e2e8f0; font-family: 'Courier New', Consolas, monospace; white-space: pre; }
code.hljs { font-size: 12.5px !important; line-height: 1.6 !important; padding: 18px 20px !important; }
.steps { display: flex; flex-direction: column; gap: 12px; }
.step { display: flex; gap: 14px; align-items: flex-start; }
.step-n { width: 26px; height: 26px; border-radius: 50%; background: rgba(34,211,238,0.1); border: 1px solid rgba(34,211,238,0.2); color: #22d3ee; font-size: 11px; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 1px; }
.step-text { font-size: 13px; color: rgba(255,255,255,0.7); line-height: 1.6; }
.step-text code { font-family: 'Courier New', monospace; font-size: 12px; background: rgba(255,255,255,0.07); padding: 1px 6px; border-radius: 4px; color: #22d3ee; }
.note { font-size: 12.5px; color: rgba(255,255,255,0.45); background: rgba(245,158,11,0.06); border: 1px solid rgba(245,158,11,0.15); border-radius: 10px; padding: 12px 16px; line-height: 1.6; margin-top: 14px; }
.note strong { color: rgba(245,158,11,0.8); }
</style>
